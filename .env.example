# Server-side — Supabase project (see Supabase dashboard → Project Settings → API)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Client-side (Vite-inlined at build time — must be set as Vercel *build* env vars, not just runtime)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Server-side — Google Gemini API (embeddings + chat generation)
GEMINI_API_KEY=
